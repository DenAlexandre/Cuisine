{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "server: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/server" },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "client: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/client" },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "server: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/server" },
      "isBackground": true,
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serveur démarré sur"
        }
      }
    },
    {
      "label": "client: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/client" },
      "isBackground": true,
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
